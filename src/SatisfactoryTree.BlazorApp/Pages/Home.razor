@page "/"
@code {
    public class Product
    {
        public Product(string partId, string recipeId, double quantity)
        {
            PartId = partId;
            RecipeId = recipeId;
            Quantity = quantity;
        }
        public string PartId { get; set; }
        public string RecipeId { get; set; }
        public double Quantity { get; set; }
    }
    public class Part
    {
        public Part(string partId, string partName)
        {
            PartId = partId;
            PartName = partName;
        }
        public string PartId { get; set; }
        public string PartName { get; set; }
    }
    public class Recipe
    {
        public Recipe(string partId, string recipeId, string recipeName)
        {
            PartId = partId;
            RecipeId = recipeId;
            RecipeName = recipeName;
        }
        public string PartId { get; set; }
        public string RecipeId { get; set; }
        public string RecipeName { get; set; }
    }

    List<Product> Products = new() { new Product("ironPlate", "ironPlate", 30), new Product("ironIngot", "ironIngot", 45) };
    List<string> Imports = new() { "Hi", "Bye" };
    List<string> Storage = new() { "Hi", "Bye" };
    List<Part> Parts = new() { new Part("ironIngot", "Iron Ingot"), new Part("ironPlate", "Iron Plate") };
    List<Recipe> Recipes = new() { new Recipe("ironIngot", "ironIngot", "Iron Ingots"), new Recipe("ironPlate", "ironPlate", "Iron Plates"), new Recipe("ironPlate", "alt_SteelPlate", "Alt: Steel Plates") };
}

<PageTitle>Home</PageTitle>

<h3>Products</h3>
<table class="table">
    <thead>
    <tr>
        <th scope="col">Part</th>
        <th scope="col">Recipe</th>
        <th scope="col">Quantity</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var product in Products)
    {
        <tr>
            <td>
                <select class="form-control" @bind="@product.PartId">
                    <option value=""></option>
                    @foreach (var part in Parts)
                    {
                        <option value="@part.PartId">@part.PartName</option>
                    }
                </select>
            </td>
            <td>
                <select class="form-control" @bind="@product.RecipeId">
                    @foreach (var recipe in Recipes)
                    {
                        <option value="@recipe.RecipeId">@recipe.RecipeName</option>
                    }
                </select>
            </td>
            <td><input type="text" class="form-control" @bind="product.Quantity"></td>
        </tr>
    }
    </tbody>
</table>

<h3>Imports</h3>
<table>
    <tr>
        <td>Factory</td>
        <td>Part</td>
        <td>Quantity</td>
    </tr>
    @foreach (var item in Imports)
    {
        @item<br>
    }
</table>

<h3>Storage</h3>
<table>
    <tr>
        <td>Part</td>
        <td>Quantity</td>
    </tr>
    @foreach (var item in Storage)
    {
        @item<br>
    }
</table>